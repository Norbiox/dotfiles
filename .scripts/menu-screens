#!/bin/bash
# Select and apply a screen layout profile with the menu.
# Backward-compatible: Wayland uses kanshi, X11 uses autorandr.

if [ -n "$WAYLAND_DISPLAY" ] || [ "$XDG_SESSION_TYPE" = "wayland" ]; then
    backend="kanshi"
    # Profile names are declared as `profile <name> {` in the kanshi config.
    profiles=$(grep -oP '^\s*profile\s+\K[^ {]+' "${XDG_CONFIG_HOME:-$HOME/.config}/kanshi/config" 2>/dev/null)
else
    backend="autorandr"
    profiles=$(autorandr --list 2>/dev/null)
fi

if [ -z "$profiles" ]; then
    notify-send "menu-screens" "No $backend profiles found"
    exit 1
fi

chosen=$(echo "$profiles" | menu -i -l 20 -p "Screen layout:")

if [ "$chosen" ]; then
    if [ "$backend" = "kanshi" ]; then
        kanshictl switch "$chosen"
    else
        autorandr --load "$chosen"
    fi

    if [ $? -eq 0 ]; then
        notify-send "menu-screens" "Screen layout changed to: $chosen"
        exit 0
    else
        notify-send "menu-screens" "Failed to load profile: $chosen"
        exit 1
    fi
else
    echo "Program terminated" && exit 1
fi
