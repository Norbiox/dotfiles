#!/bin/sh
# Send an IPC message to the running window manager.
# Backward-compatible: sway (swaymsg) / i3 (i3-msg).
# i3 and sway share the same IPC command + JSON reply syntax, so callers can
# use the same `-t get_tree`, `-t get_workspaces`, command strings, etc.
# Usage: wmmsg -t get_workspaces   |   wmmsg 'workspace 3'

if [ -n "$SWAYSOCK" ] || [ -n "$WAYLAND_DISPLAY" ] || [ "$XDG_SESSION_TYPE" = "wayland" ]; then
	exec swaymsg "$@"
else
	exec i3-msg "$@"
fi
